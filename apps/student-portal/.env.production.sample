# ─── Netlify Production Environment Variables for Student Portal ───
# Add these in Netlify Dashboard -> Site settings -> Environment variables

# Backend Microservice URLs (Replace with your actual hosted production URLs, e.g. on Render/Railway/Fly.io)
NEXT_PUBLIC_API_URL="https://api.yourdomain.com/auth"
NEXT_PUBLIC_EXAM_API_URL="https://api.yourdomain.com/exam"
NEXT_PUBLIC_WS_URL="wss://socket.yourdomain.com/notifications"
NEXT_PUBLIC_STREAMING_URL="wss://socket.yourdomain.com/streaming"

# URL of the hosted Admin Dashboard (for redirection when admin/teacher logs in via Student Portal)
NEXT_PUBLIC_ADMIN_DASHBOARD_URL="https://admin-examplatform.netlify.app"

# Firebase Credentials (If using Firebase Google Sign-In)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="ai-proctor-exam-platform.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="ai-proctor-exam-platform"
